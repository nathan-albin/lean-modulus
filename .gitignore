/.lake
tmp

# leanblueprint generated output (rebuilt by `leanblueprint web`/`pdf`/`checkdecls`)
/blueprint/web/
/blueprint/print/
/blueprint/lean_decls
/blueprint/src/*.paux

# Jekyll build output for the home page (rebuilt by `jekyll build`/`bundle exec jekyll serve`)
/home_page/_site/
/home_page/.jekyll-cache/
/home_page/.jekyll-metadata
/home_page/vendor/

# Local copy of the built blueprint, so the homepage's embedded dependency graph
# resolves when previewing with `bundle exec jekyll serve` (see CONTRIBUTING.md).
# CI assembles the equivalent copy itself; Jekyll won't follow a symlink here.
/home_page/blueprint/
